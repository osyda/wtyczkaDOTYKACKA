# --- Dotykačka API v2 ---
# Skopiuj ten plik do .env.local (lokalnie) lub ustaw w Vercel → Settings → Environment Variables.
# Bez tych zmiennych aplikacja działa w trybie DEMO (przykładowe menu).

# Bazowy URL API (zwykle bez zmian)
DOTYKACKA_BASE_URL=https://api.dotykacka.cz/v2

# Dane aplikacji klienckiej (z rejestracji w Dotykačce)
DOTYKACKA_CLIENT_ID=
DOTYKACKA_CLIENT_SECRET=

# Token długoterminowy uzyskany przez Connector v2 (NIGDY nie commituj!)
DOTYKACKA_REFRESH_TOKEN=

# Identyfikatory chmury i oddziału
DOTYKACKA_CLOUD_ID=
DOTYKACKA_BRANCH_ID=
