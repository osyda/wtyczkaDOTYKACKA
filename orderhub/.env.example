# --- Dotykačka API v2 ---
# Skopiuj ten plik do .env.local (lokalnie) lub ustaw w Vercel → Settings → Environment Variables.
# Bez tych zmiennych aplikacja działa w trybie DEMO (przykładowe menu).

# Bazowy URL API (zwykle bez zmian)
DOTYKACKA_BASE_URL=https://api.dotykacka.cz/v2

# Dane aplikacji klienckiej (z rejestracji w Dotykačce)
DOTYKACKA_CLIENT_ID=
DOTYKACKA_CLIENT_SECRET=

# Token długoterminowy uzyskany przez Connector v2 (NIGDY nie commituj!)
DOTYKACKA_REFRESH_TOKEN=

# Identyfikatory chmury i oddziału
DOTYKACKA_CLOUD_ID=
DOTYKACKA_BRANCH_ID=

# Produkty POS reprezentujące koszt dostawy (opcjonalne, do zgodności sumy w POS)
DOTYKACKA_DELIVERY_CITY_PRODUCT_ID=
DOTYKACKA_DELIVERY_KM_PRODUCT_ID=

# --- Automatyczne liczenie dostawy ---
# Klucz OpenRouteService (darmowy: https://openrouteservice.org) — liczy realną odległość drogową.
# Bez klucza działa fallback (ręczne km w checkoutcie).
ORS_API_KEY=
# Współrzędne lokalu Mamma Rosa (domyślnie centrum Kościerzyny) — do potwierdzenia.
RESTAURANT_LAT=54.1226
RESTAURANT_LNG=17.9766
# Promień „terenu Kościerzyny" (km) dla stawki płaskiej przy liczeniu z GPS.
DELIVERY_CITY_RADIUS_KM=3

# --- Godziny otwarcia (blokada zamówień po zamknięciu) ---
# Najlepiej: klucz Google (Places API) — godziny pobierają się same z wizytówki Google
# i aktualizują po każdej zmianie w profilu firmy (cache 6 h).
GOOGLE_MAPS_API_KEY=
# Fraza, po której szukamy wizytówki (zwykle bez zmian).
GOOGLE_PLACE_QUERY=Pizzeria Mammarosa Kościerzyna
# Alternatywa bez klucza Google: godziny wpisane ręcznie, np.:
# OPENING_HOURS=pn-czw 11:00-21:00; pt-sb 11:00-22:00; nd 12:00-21:00
# (dzień zamknięty: "wt zamknięte"). Bez obu zmiennych: codziennie 11:00-21:00.
OPENING_HOURS=
# Ile minut przed zamknięciem przyjmujemy ostatnie zamówienie (domyślnie 20).
LAST_ORDER_MIN=20

# --- Centralka telefoniczna (CTI) ---
# Klucz webhooka /api/cti/call — centralka/aplikacja musi go podawać (?key=...).
# Wymyśl długi losowy ciąg. Pusty = webhook otwarty (tylko na czas testów!).
CTI_WEBHOOK_KEY=

# --- Kierowcy ---
# Lista kierowców do przypisywania dostaw w panelu (rozliczenie kursów w „Dziś").
# Po prostu imiona po przecinku:
DRIVERS=

# --- Ochrona panelu obsługi ---
# PIN do /panel (monitor kelnerki). Pusty = brak ochrony (DEMO/local).
# W produkcji USTAW koniecznie, np. losowe 4-6 cyfr.
STAFF_PIN=

# --- Trwały magazyn (Vercel KV / Upstash) ---
# Ustawiane automatycznie przez Vercel przy podpięciu KV. Bez nich = magazyn w pamięci.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# BEZPIECZNIK: wysyłka rachunków do POS włącza się dopiero po ustawieniu "true".
# Na czas testów zostaw puste/false — zamówienia będą symulowane nawet z kluczami.
DOTYKACKA_SEND_ORDERS=false
